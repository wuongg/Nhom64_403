## XanhSM Help Center AI - Example environment configuration
## Copy this file to `.env` and fill in values as needed.

# --- Core LLM ---
# If not set, the app will run in preview mode (no OpenAI call).
OPENAI_API_KEY=
MODEL=gpt-4o-mini

# --- Data / Storage ---
RAW_DIR=./raw
DB_URL=sqlite:///./xanhsm_helpcenter.db

# --- API / Frontend ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
TOP_K=5
ENABLE_DEBUG_FIELDS=true

# --- Optional web search ---
ENABLE_WEB_SEARCH=false
SERPER_API_KEY=
SERPAPI_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_KB_SCORE_THRESHOLD=2
